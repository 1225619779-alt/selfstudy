REPO_ROOT=/home/pang/projects/DDET-MTD-q1-case39
CASE_NAME=case39
PATCH_SCRIPT=/home/pang/projects/DDET-MTD-q1-case39/case39_first_batch_patch.py

# patch 大概率已经打过；重复打可能失败
RUN_PATCH=0

# symlink 最省空间，也足够做 bridge 验证
STAGE_MODE=symlink

# 保险起见，覆盖已有 stage 目标，避免半途因文件已存在而停掉
FORCE_STAGE=1

# 用 q1-case39 工作区内现成的 case14 canonical 资产做 bridge 验证
# 注意：这不是正式 case39 科学结果，只是验证 bridge / oracle_confirm 主链
CLEAN_SRC=/home/pang/projects/DDET-MTD-q1-case39/metric/case14/metric_clean_alarm_scores_full.npy
ATTACK_SRC=/home/pang/projects/DDET-MTD-q1-case39/metric/case14/metric_attack_alarm_scores_400.npy
TRAIN_SRC=/home/pang/projects/DDET-MTD-q1-case39/metric/case14/mixed_bank_fit.npy
VAL_SRC=/home/pang/projects/DDET-MTD-q1-case39/metric/case14/mixed_bank_eval.npy

# generic smoke 价值低于 oracle_confirm；为了提高过夜成功率，这里关闭
TEST_SMOKE_SRC=/home/pang/projects/DDET-MTD-q1-case39/metric/case14/mixed_bank_test_holdout.npy
RUN_GENERIC_SMOKE=0

# q1-case39 工作区没有 blind confirm 原始 test banks；从旧仓库挂过来
LOCAL_CASE39_HOLDOUT_BANKS_V1_DIR=/home/pang/projects/DDET-MTD/metric/case14/phase3_confirm_blind_v1/banks
LOCAL_CASE39_HOLDOUT_BANKS_V2_DIR=/home/pang/projects/DDET-MTD/metric/case14/phase3_confirm_blind_v2/banks

# phase3_oracle_family 的 dev-screen summary；启动前建议先确认 winner_variant=oracle_protected_ec
CASE14_FROZEN_ORACLE_WINNER_SUMMARY_JSON=/home/pang/projects/DDET-MTD-q1-case39/metric/case14/phase3_oracle_family/screen_train_val_summary.json
RUN_ORACLE_CONFIRM=1

WORKDIR=.
