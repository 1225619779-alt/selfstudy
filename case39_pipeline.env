# 复制为 case39_pipeline.env 后按需修改

# 仓库根目录
REPO_ROOT=/home/pang/projects/DDET-MTD-q1-case39

# case 名称
CASE_NAME=case39

# 已下载到本地的 patch 脚本路径
PATCH_SCRIPT=/home/pang/projects/DDET-MTD-q1-case39/case39_first_batch_patch.py

# 是否先应用第一批 patch；1=应用，0=跳过
RUN_PATCH=1

# 资产 staging 方式：symlink / copy / hardlink
STAGE_MODE=symlink

# 若目标文件已存在，是否强制覆盖；1=覆盖，0=不覆盖
FORCE_STAGE=0

# case39 的 canonical 资产来源。若你已有统一根目录，下面 4 行直接指到具体文件即可。
CLEAN_SRC=/ABS/PATH/TO/case39_assets/metric_clean_alarm_scores_full.npy
ATTACK_SRC=/ABS/PATH/TO/case39_assets/metric_attack_alarm_scores_400.npy
TRAIN_SRC=/ABS/PATH/TO/case39_assets/mixed_bank_fit.npy
VAL_SRC=/ABS/PATH/TO/case39_assets/mixed_bank_eval.npy

# 可选：generic smoke 用的单个 test bank；没有就留空
TEST_SMOKE_SRC=

# blind confirm 的 holdout 测试 bank 目录。目录内文件名要与 manifest 里的 mixed_bank_test_*.npy basename 对上。
LOCAL_CASE39_HOLDOUT_BANKS_V1_DIR=/ABS/PATH/TO/case39_holdouts_v1
LOCAL_CASE39_HOLDOUT_BANKS_V2_DIR=/ABS/PATH/TO/case39_holdouts_v2

# case14 冻结 winner 的 dev-screen summary json
CASE14_FROZEN_ORACLE_WINNER_SUMMARY_JSON=/ABS/PATH/TO/case14_oracle_winner_summary.json

# 是否跑 generic holdout wiring smoke；需要 TEST_SMOKE_SRC 非空
RUN_GENERIC_SMOKE=1

# 是否继续跑 oracle_confirm 主链
RUN_ORACLE_CONFIRM=1

# manifest builder 的 workdir，一般保持 .
WORKDIR=.
